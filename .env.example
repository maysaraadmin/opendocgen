# OpenDocGen Environment Configuration
# Copy to .env and customize

# ==========================================
# Core Application Settings
# ==========================================
DEBUG=false
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-this-to-a-random-secret-key

# ==========================================
# Ollama (Local LLM) Configuration
# ==========================================
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=llama3.2
ALTERNATE_MODEL=mistral
CODE_MODEL=codellama
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_NUM_GPU=35
OLLAMA_KEEP_ALIVE=24h

# ==========================================
# SearXNG (Search Engine) Configuration
# ==========================================
SEARXNG_URL=http://localhost:8080
SEARXNG_TIMEOUT=30
SEARXNG_SAFE_SEARCH=0

# ==========================================
# Browserless (Browser Automation)
# ==========================================
BROWSERLESS_URL=http://localhost:3000
BROWSERLESS_TOKEN=your-secret-token-here
BROWSERLESS_TIMEOUT=60000

# ==========================================
# Chroma (Vector Database)
# ==========================================
CHROMA_URL=http://localhost:8000
CHROMA_PERSIST_DIRECTORY=./data/chroma

# ==========================================
# Unstructured (Document Processing)
# ==========================================
UNSTRUCTURED_URL=http://localhost:8000
UNSTRUCTURED_TIMEOUT=120

# ==========================================
# Storage Paths
# ==========================================
UPLOAD_DIR=./data/uploads
DOWNLOAD_DIR=./data/downloads
OUTPUT_DIR=./data/output
CACHE_DIR=./data/cache
LOG_DIR=./data/logs

# ==========================================
# Security Settings
# ==========================================
MAX_FILE_SIZE=104857600  # 100MB
ALLOWED_EXTENSIONS=pdf,docx,txt,md,csv,json,xlsx
RATE_LIMIT_PER_MINUTE=60

# ==========================================
# Feature Flags
# ==========================================
ENABLE_GPU=true
ENABLE_MEMORY=true
ENABLE_CACHE=true
ENABLE_WEB_SCRAPING=true
ENABLE_CODE_EXECUTION=true
